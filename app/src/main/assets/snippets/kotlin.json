{
  "fun": "fun $1($2): $3 {\n    $4\n}",
  "class": "class $1 {\n    $2\n}",
  "data": "data class $1(\n    val $2: $3\n)",
  "when": "when ($1) {\n    $2 -> $3\n    else -> $4\n}",
  "coroutine": "viewModelScope.launch {\n    $1\n}",
  "flow": "flow {\n    emit($1)\n}",
  "companion": "companion object {\n    $1\n}",
  "sealed": "sealed class $1 {\n    data class $2($3) : $1()\n}",
  "extension": "fun $1.$2($3): $4 {\n    $5\n}",
  "lambda": "{ $1 -> $2 }"
}

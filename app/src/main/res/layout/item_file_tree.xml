<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="36dp"
    android:orientation="horizontal" android:gravity="center_vertical" android:paddingEnd="8dp">
    <ImageView android:id="@+id/ivIcon" android:layout_width="16dp" android:layout_height="16dp" android:layout_marginEnd="6dp"/>
    <TextView android:id="@+id/tvFileName" android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:textColor="#FFFFFF" android:textSize="13sp"
        android:fontFamily="monospace" android:ellipsize="end" android:singleLine="true"/>
</LinearLayout>

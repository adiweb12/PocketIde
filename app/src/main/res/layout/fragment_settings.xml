<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="#1E1E2E">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Editor Theme" android:textColor="#888888" android:textSize="12sp"/>
        <Spinner android:id="@+id/spinnerTheme" android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Dark Mode" android:textColor="#FFFFFF" android:layout_marginTop="16dp"/>
        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchDarkMode"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Line Numbers" android:textColor="#FFFFFF" android:layout_marginTop="8dp"/>
        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchLineNumbers"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Word Wrap" android:textColor="#FFFFFF" android:layout_marginTop="8dp"/>
        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchWordWrap"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <Button android:id="@+id/btnSaveSettings" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="Save Settings"
            android:layout_marginTop="24dp" android:backgroundTint="#A855F7"/>
    </LinearLayout>
</ScrollView>

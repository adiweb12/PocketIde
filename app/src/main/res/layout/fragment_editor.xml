<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#1E1E2E">
    <com.google.android.material.tabs.TabLayout android:id="@+id/tabLayout"
        android:layout_width="match_parent" android:layout_height="40dp"
        android:background="#2D2D3F" app:tabMode="scrollable"/>
    <FrameLayout android:id="@+id/editorWebViewContainer" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="40dp"
        android:orientation="horizontal" android:background="#2D2D3F" android:gravity="center_vertical" android:paddingHorizontal="8dp">
        <Button android:id="@+id/btnSave" style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Save" android:textColor="#A855F7"/>
        <Button android:id="@+id/btnRun" style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="▶ Run" android:textColor="#22C55E"/>
    </LinearLayout>
</LinearLayout>
